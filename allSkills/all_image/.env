ALL_IMAGE_GOOGLE_API_KEY=AIzaSyAQlOh5gnPRNTKrnPXYlCuLHAqgnLHc_GY
GOOGLE_API_KEY=AIzaSyAQlOh5gnPRNTKrnPXYlCuLHAqgnLHc_GY
# 首选：gemini-3-pro-image-preview (Nano Banana Pro - SOTA，但可能过载)
# 备选：google_flash provider 自动使用 gemini-2.0-flash-exp-image-generation
ALL_IMAGE_GOOGLE_MODEL=gemini-3-pro-image-preview
ALL_IMAGE_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# 智能代理：优先直连，失败后自动启用代理
# 代理会在直连失败时自动启用
ALL_IMAGE_PROXY=http://127.0.0.1:60821
# ModelScope (免费额度)
ALL_IMAGE_MODELSCOPE_API_KEY=ms-your-key-here
