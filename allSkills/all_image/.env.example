# all-image 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Key

# ============================================================
# === ⭐ 首选：Google AI Studio (最高质量) ===
# ============================================================
# 获取方式：访问 https://ai.google.dev/ 获取 API Key
# 特点：Gemini 3 Pro / Imagen 3，支持文生图 + 图生图，支持最高 4K 分辨率
ALL_IMAGE_GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY=your_google_api_key_here  # 兼容 image-assistant
ALL_IMAGE_GOOGLE_MODEL=gemini-3-pro-image-preview
ALL_IMAGE_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ============================================================
# === 兜底：云雾 API (快速、高质量) ===
# ============================================================
# 获取方式：访问云雾官网注册并获取 API Key
# 特点：Gemini 2.5 Flash，速度快，高质量
ALL_IMAGE_YUNWU_API_KEY=your_yunwu_api_key_here
YUNWU_API_KEY=your_yunwu_api_key_here  # 兼容 image-assistant
ALL_IMAGE_YUNWU_MODEL=gemini-2.5-flash-image-preview
ALL_IMAGE_YUNWU_BASE_URL=https://yunwu.ai/v1beta/models

# ============================================================
# === 可选：ModelScope (免费额度) ===
# ============================================================
# 获取方式：访问 https://modelscope.cn/ 获取 API Key
# 特点：免费额度 2000张/天，支持图生图
ALL_IMAGE_MODELSCOPE_API_KEY=ms-your-modelscope-api-key-here
MODELSCOPE_API_KEY=ms-your-modelscope-api-key-here  # 兼容 image-assistant
ALL_IMAGE_MODELSCOPE_MODEL=Tongyi-MAI/Z-Image-Turbo
ALL_IMAGE_MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
ALL_IMAGE_MODELSCOPE_POLL_TIMEOUT=300
ALL_IMAGE_MODELSCOPE_POLL_INTERVAL=5

# ============================================================
# === 可选：OpenAI (DALL-E) ===
# ============================================================
# 获取方式：访问 https://platform.openai.com/ 获取 API Key
# 特点：DALL-E 3，高质量
ALL_IMAGE_OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here  # 兼容 image-assistant
ALL_IMAGE_OPENAI_MODEL=dall-e-3
ALL_IMAGE_OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# === 可选：APIMart (第三方聚合) ===
# ============================================================
# 获取方式：访问 APIMart 官网注册并获取 TOKEN
# 特点：支持批量生成，异步+轮询
ALL_IMAGE_APIMART_TOKEN=your_apimart_token_here
APIMART_TOKEN=your_apimart_token_here  # 兼容 image-assistant
ALL_IMAGE_APIMART_MODEL=gemini-3-pro-image-preview
ALL_IMAGE_APIMART_URL=https://api.apimart.ai/v1/images/generations
ALL_IMAGE_APIMART_POLL_TIMEOUT=300
ALL_IMAGE_APIMART_POLL_INTERVAL=5

# ============================================================
# === 配置说明 ===
# ============================================================
#
# 1. 优先级策略（自动降级）：
#    Google AI (首选) → 云雾 API → ModelScope → OpenAI → APIMart
#
# 2. Google AI 特点：
#    - ⭐ 最高质量（Gemini 3 Pro / Imagen 3）
#    - ✅ 支持文生图（Text-to-Image）
#    - ✅ 支持图生图（Image-to-Image）
#    - ✅ 支持多种分辨率：
#      - 标准：1024x1024, 1792x1024 (16:9), 1024x1792 (9:16)
#      - 高质量：2048x2048, 3072x3072
#      - 超高清：4096x4096 (4K，推荐)
#
# 3. Windows 设置环境变量：
#    setx GOOGLE_API_KEY "your_api_key"
#    或在 PowerShell 中：
#    [System.Environment]::SetEnvironmentVariable('GOOGLE_API_KEY', 'your_api_key', 'User')
#
# 4. Linux/Mac 设置环境变量：
#    在 ~/.bashrc 或 ~/.zshrc 中添加：
#    export GOOGLE_API_KEY="your_api_key"
#
# 5. 环境变量兼容性：
#    - all-image 支持两种命名方式：ALL_IMAGE_* 和原始命名
#    - 原始命名方式（如 GOOGLE_API_KEY）优先级更高
#    - 这样可以与 image-assistant 等其他 skill 共用配置
#
# 6. 测试配置：
#    python -c "from all_image import ImageGenerator; gen = ImageGenerator(); print(gen.get_available_providers())"
